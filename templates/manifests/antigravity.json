{
  "version": 1,
  "artifacts": [
    {
      "id": "commands",
      "source": {
        "type": "templateDir",
        "fromDir": "agents/antigravity/commands",
        "toDir": "{{AGENT_COMMANDS_DIR}}"
      },
      "category": "skills"
    },
    {
      "id": "doc_antigravity",
      "source": {
        "type": "templateFile",
        "from": "agents/antigravity/docs/antigravity-context.md",
        "toDir": ".",
        "rename": "antigravity-context.md"
      },
      "category": "docs"
    },
    {
      "id": "settings_rules",
      "source": {
        "type": "templateDir",
        "fromDir": "shared/settings/rules",
        "toDir": "{{AURA_DIR}}/settings/rules"
      },
