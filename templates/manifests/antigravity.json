    },
    {
      "id": "settings_templates",
      "source": {
        "type": "templateDir",
        "fromDir": "shared/settings/templates",
        "toDir": "{{AURA_DIR}}/settings/templates"
      },
      "category": "settings"
    },
    {
      "id": "workflow_full_sdd",
      "source": {
        "type": "templateFile",
        "from": "shared/workflows/full-sdd.json",
