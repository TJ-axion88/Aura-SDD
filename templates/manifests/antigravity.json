      },
      "category": "workflows"
    },
    {
      "id": "workflow_tdd",
      "source": {
        "type": "templateFile",
        "from": "shared/workflows/tdd.json",
        "toDir": "{{AURA_DIR}}/workflows/definitions"
      },
      "category": "workflows"
    },
    {
      "id": "workflow_lean_sdd",
      "source": {
        "type": "templateFile",
        "from": "shared/workflows/lean-sdd.json",
        "toDir": "{{AURA_DIR}}/workflows/definitions"
      },
      "category": "workflows"
    }
  ]
}
